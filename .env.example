# ─────────────────────────────────────────────────────────
#  Zippy Minds Academy — Environment Variables
#  Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────
# LOCAL DEVELOPMENT (SQLite — no setup needed, leave blank)
# DATABASE_URL is auto-resolved to ./dev.db when not set

# PRODUCTION (Turso — free at turso.tech)
# 1. Install CLI:  brew install tursodatabase/tap/turso
# 2. Login:        turso auth login
# 3. Create DB:    turso db create zippy-minds
# 4. Get URL:      turso db show zippy-minds --url
# 5. Get token:    turso db tokens create zippy-minds
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Session ───────────────────────────────────────────────
# Must be at least 32 characters. Change this in production!
SESSION_SECRET="zippy-minds-super-secret-key-change-in-production-2025"

# ── Email (Resend — free at resend.com, 3000 emails/month) ─
# 1. Sign up at resend.com
# 2. Add & verify your domain
# 3. Create an API key
# Leave blank in dev — OTP codes will print to the terminal instead
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="Zippy Minds Academy <noreply@yourdomain.com>"

# ── Zoom (Server-to-Server OAuth — free at marketplace.zoom.us) ──
# 1. Go to https://marketplace.zoom.us → Build App → Server-to-Server OAuth
# 2. Name it "Zippy Minds Scheduler" → Activate
# 3. Copy Account ID, Client ID, Client Secret (shown on app page)
# 4. Under Scopes → Add: meeting:write:admin
# Leave blank in dev — bookings save as PENDING without a Zoom link
ZOOM_ACCOUNT_ID="your-zoom-account-id"
ZOOM_CLIENT_ID="your-zoom-client-id"
ZOOM_CLIENT_SECRET="your-zoom-client-secret"

# ── Cloudinary (Image Storage — free at cloudinary.com) ──
# 1. Sign up at cloudinary.com
# 2. Dashboard → copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── App URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://yourdomain.com"
