generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  phone          String?
  role           String   @default("PARENT")
  password       String
  approvalStatus String   @default("APPROVED") // PENDING | APPROVED | REJECTED (for TUTOR role)
  subjects       String   @default("[]")       // JSON array of subject strings, e.g. '["Mathematics","Science"]'
  availability   String   @default("{}")       // JSON: { "Mon": ["9:00 AM", "10:00 AM"], ... }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String?
  parentName    String
  parentEmail   String
  childName     String
  childAge      String
  grade         String
  timezone      String
  subject       String
  tutorName     String
  tutorInitials String
  date          String
  timeSlot      String
  notes          String   @default("")
  monthlyPrice   Int
  status         String   @default("PENDING")
  zoomLink       String?
  zoomStartUrl   String?
  zoomMeetingId  String?
  declinedTutors String   @default("[]")   // JSON array of tutor names who already declined
  needsAdmin     Boolean  @default(false)  // true when all available tutors declined
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  from      String
  email     String
  subject   String
  message   String
  priority  String   @default("medium")  // low | medium | high
  status    String   @default("open")    // open | closed
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  price       Int      @default(199)
  status      String   @default("active")  // active | inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("PDF")     // PDF | Image | Link
  subject   String
  size      String   @default("")
  icon      String   @default("📄")
  url       String   @default("")        // download or view URL
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoLesson {
  id        String   @id @default(cuid())
  title     String
  subject   String
  duration  String   @default("")
  thumbnail String   @default("📹")      // emoji or image URL
  videoUrl  String   @default("")        // YouTube embed or direct URL
  views     Int      @default(0)
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecordedSession {
  id            String   @id @default(cuid())
  title         String
  description   String   @default("")
  subject       String   @default("")
  studentName   String   @default("")          // blank = shared with all parent students of this tutor
  tutorName     String   @default("")
  videoUrl      String                         // Zoom cloud link, YouTube, or Vercel Blob URL
  duration      String   @default("")          // e.g. "45:30"
  fileSize      String   @default("")
  uploadedBy    String                         // user name who uploaded
  uploadedByRole String  @default("TUTOR")     // "ADMIN" | "TUTOR"
  visibility    String   @default("individual") // "individual" | "all"
  createdAt     DateTime @default(now())
}

model TutorMaterial {
  id          String   @id @default(cuid())
  tutorName   String                         // matches session.name
  tutorEmail  String   @default("")
  studentName String   @default("")          // blank when visibility = "all"
  subject     String   @default("")
  title       String
  fileUrl     String                         // Vercel Blob URL
  fileType    String   @default("PDF")       // PDF | Image | Doc | Other
  fileSize    String   @default("")
  notes       String   @default("")
  visibility  String   @default("individual") // "individual" | "all"
  createdAt   DateTime @default(now())
}

model TutorMonthlyAvailability {
  id        String   @id @default(cuid())
  tutorId   String
  tutorName String
  monthYear String   // e.g. "2025-07"
  slots     String   // JSON: {"Mon":["2:00 PM","3:00 PM"],"Tue":["2:00 PM"],…}
  timezone  String   @default("Asia/Kolkata")
  isLocked  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilityChangeRequest {
  id              String   @id @default(cuid())
  tutorId         String
  tutorName       String
  monthYear       String
  currentSlots    String   // JSON snapshot of slots before change
  proposedSlots   String   // JSON of proposed new slots
  reason          String   @default("")
  status          String   @default("PENDING_PARENT")
  // PENDING_PARENT | ALL_APPROVED | ANY_REJECTED | APPLIED | CANCELLED
  parentApprovals String   @default("{}")
  // JSON: {"email@a.com":{"name":"Sarah","token":"abc123","status":"pending"}}
  adminId         String   @default("")
  adminName       String   @default("")
  createdAt       DateTime @default(now())
  expiresAt       DateTime
}
