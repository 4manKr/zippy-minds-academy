generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  phone          String?
  role           String   @default("PARENT")
  password       String
  approvalStatus String   @default("APPROVED") // PENDING | APPROVED | REJECTED (for TUTOR role)
  subjects       String   @default("[]")       // JSON array of subject strings, e.g. '["Mathematics","Science"]'
  availability   String   @default("{}")       // JSON: { "Mon": ["9:00 AM", "10:00 AM"], ... }
  tutorPriority  Int      @default(999)        // lower = assigned first (1 = top priority)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String?
  parentName    String
  parentEmail   String
  childName     String
  childAge      String
  grade         String
  timezone      String
  subject       String
  tutorName     String
  tutorInitials String
  date          String
  timeSlot      String
  notes            String   @default("")
  whatsappNumber   String   @default("")
  monthlyPrice     Int
  status         String   @default("PENDING")
  zoomLink       String?
  zoomStartUrl   String?
  zoomMeetingId  String?
  declinedTutors String   @default("[]")   // JSON array of tutor names who already declined
  needsAdmin     Boolean  @default(false)  // true when all available tutors declined
  reminderSent   Boolean  @default(false)  // true once the 30-min reminder has been sent
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  from      String
  email     String
  subject   String
  message   String
  priority  String   @default("medium")  // low | medium | high
  status    String   @default("open")    // open | closed
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Subject = top-level header (e.g. "Mathematics")
model Subject {
  id            String   @id @default(cuid())
  name          String   @unique
  ageGroup      String   @default("")   // e.g. "6–12 years"
  totalDuration String   @default("")   // e.g. "12 months"
  color         String   @default("")   // hex color e.g. "#6366f1" for card accent
  status        String   @default("active") // active | inactive
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  courses       Course[]
}

// Course = sub-course / plan under a Subject
model Course {
  id              String   @id @default(cuid())
  subjectId       String?                      // FK → Subject
  name            String   @unique
  description     String   @default("")        // HTML rich text
  thumbnail       String   @default("")        // image URL for card thumbnail
  ageRange        String   @default("")        // e.g. "6–9 years"
  teacherName     String   @default("")
  showTeacher     Boolean  @default(false)
  rating          Float    @default(0)
  price                  Int      @default(199)  // INR  — tutor-wise model total price
  priceUSD               Int      @default(15)   // USD  — tutor-wise model total price
  originalPrice          Int      @default(0)    // INR  crossed-out price (0 = no discount)
  originalPriceUSD       Int      @default(0)    // USD  crossed-out price (0 = no discount)
  // ── Course-wise model per-session pricing ──────────────────────────────────
  pricePerSession        Int      @default(0)    // INR  group class per session
  privatePricePerSession Int      @default(0)    // INR  1-to-1 class per session
  pricePerSessionUSD     Int      @default(0)    // USD  group class per session
  privatePricePerSessionUSD Int   @default(0)    // USD  1-to-1 class per session
  sessionDurationMins    Int      @default(60)   // session length in minutes
  durationValue   Int      @default(1)
  durationUnit    String   @default("months")  // days | weeks | months
  sessionsPerWeek Int      @default(1)
  sortOrder       Int      @default(0)         // lower = shown first
  status          String   @default("active")  // active | inactive
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  subject         Subject? @relation(fields: [subjectId], references: [id])
}

// Blog posts — written and published by admin
model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @default("")     // HTML rich text from editor
  excerpt   String   @default("")     // short summary shown on listing card
  thumbnail String   @default("")     // cover image URL
  author    String   @default("")
  tags      String   @default("[]")   // JSON array of tag strings
  status    String   @default("draft") // draft | published
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Free Resources — publicly viewable, login required to download
model FreeResource {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  fileUrl     String   @default("")   // Cloudinary URL (raw or image)
  fileType    String   @default("")   // MIME type, e.g. "application/pdf"
  fileSize    String   @default("")   // human-readable, e.g. "2.4 MB"
  thumbnail   String   @default("")   // optional cover image URL
  category    String   @default("Other")  // Worksheets | Study Guides | Presentations | Videos | Audio | Templates | Other
  tags        String   @default("[]") // JSON array of tag strings
  downloads   Int      @default(0)
  status      String   @default("draft") // draft | published
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Lead capture — website popup (name + WhatsApp number)
model Lead {
  id        String   @id @default(cuid())
  name      String
  whatsapp  String
  page      String   @default("")   // URL path where the popup was shown
  createdAt DateTime @default(now())
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("PDF")     // PDF | Image | Link
  subject   String
  size      String   @default("")
  icon      String   @default("📄")
  url       String   @default("")        // download or view URL
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoLesson {
  id        String   @id @default(cuid())
  title     String
  subject   String
  duration  String   @default("")
  thumbnail String   @default("📹")      // emoji or image URL
  videoUrl  String   @default("")        // YouTube embed or direct URL
  views     Int      @default(0)
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecordedSession {
  id            String   @id @default(cuid())
  title         String
  description   String   @default("")
  subject       String   @default("")
  studentName   String   @default("")          // blank = shared with all parent students of this tutor
  tutorName     String   @default("")
  videoUrl      String                         // Zoom cloud link, YouTube, or Vercel Blob URL
  duration      String   @default("")          // e.g. "45:30"
  fileSize      String   @default("")
  uploadedBy    String                         // user name who uploaded
  uploadedByRole String  @default("TUTOR")     // "ADMIN" | "TUTOR"
  visibility    String   @default("individual") // "individual" | "all"
  createdAt     DateTime @default(now())
}

model TutorMaterial {
  id          String   @id @default(cuid())
  tutorName   String                         // matches session.name
  tutorEmail  String   @default("")
  studentName String   @default("")          // blank when visibility = "all"
  subject     String   @default("")
  title       String
  fileUrl     String                         // Vercel Blob URL
  fileType    String   @default("PDF")       // PDF | Image | Doc | Other
  fileSize    String   @default("")
  notes       String   @default("")
  visibility  String   @default("individual") // "individual" | "all"
  createdAt   DateTime @default(now())
}

model TutorMonthlyAvailability {
  id        String   @id @default(cuid())
  tutorId   String
  tutorName String
  monthYear String   // e.g. "2025-07"
  slots     String   // JSON: {"Mon":["2:00 PM","3:00 PM"],"Tue":["2:00 PM"],…}
  timezone  String   @default("Asia/Kolkata")
  isLocked  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilityChangeRequest {
  id              String   @id @default(cuid())
  tutorId         String
  tutorName       String
  monthYear       String
  currentSlots    String   // JSON snapshot of slots before change
  proposedSlots   String   // JSON of proposed new slots
  reason          String   @default("")
  status          String   @default("PENDING_PARENT")
  // PENDING_PARENT | ALL_APPROVED | ANY_REJECTED | APPLIED | CANCELLED
  parentApprovals String   @default("{}")
  // JSON: {"email@a.com":{"name":"Sarah","token":"abc123","status":"pending"}}
  adminId         String   @default("")
  adminName       String   @default("")
  createdAt       DateTime @default(now())
  expiresAt       DateTime
}

model Payment {
  id          String   @id @default(cuid())
  userId      String?
  parentEmail String
  parentName  String
  childName   String   @default("")
  amount      Float
  currency    String   @default("INR")
  gateway     String
  gatewayId   String?
  status      String   @default("PENDING")  // PENDING | PAID | FAILED
  courseName  String
  courseId    String?
  couponCode  String   @default("")         // coupon used at checkout (empty = none)
  discount    Float    @default(0)          // discount amount applied
  createdAt   DateTime @default(now())
  sessions    MonthlySession[]
}

// Affiliate / influencer coupon codes
model Coupon {
  id               String   @id @default(cuid())
  code             String   @unique         // e.g. "RESHMA200" — uppercase enforced in API
  influencerName   String                   // e.g. "Reshma"
  discountType     String   @default("flat")  // flat | percent
  discountValue    Float    @default(0)     // ₹200 or 20 (%)
  commissionPerUse Float    @default(0)     // how much you owe influencer per valid use
  maxUses          Int?                     // null = unlimited global uses
  maxUsesPerUser   Int      @default(1)     // how many times one user can use this code
  usedCount        Int      @default(0)     // auto-incremented on each valid use
  isActive         Boolean  @default(true)
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  usages           CouponUsage[]
}

// Tracks every individual use of a coupon
model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String
  couponCode     String                     // denormalised for quick lookups
  userId         String                     // the user who used it
  userEmail      String   @default("")
  userName       String   @default("")
  subscriptionId String   @default("")      // paymentId of the purchase
  courseName     String   @default("")
  discountGiven  Float    @default(0)
  createdAt      DateTime @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id])
}

model Enrollment {
  id            String   @id @default(cuid())
  paymentId     String?
  userId        String?
  parentEmail   String
  parentName    String
  childName     String
  subject       String
  courseId      String?
  courseName    String
  dayOfWeek     String
  timeSlot      String
  timezone      String   @default("Asia/Kolkata")
  startDate     String   // first session YYYY-MM-DD
  endDate       String   // last session YYYY-MM-DD
  totalSessions Int      @default(0)
  status        String   @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  createdAt     DateTime @default(now())
  sessions      MonthlySession[]
}

model MonthlySession {
  id                String   @id @default(cuid())
  paymentId         String?
  enrollmentId      String?
  parentEmail       String
  parentName        String
  childName         String
  subject           String
  grade             String   @default("")
  tutorName         String   @default("TBD")
  tutorInitials     String   @default("??")
  dayOfWeek         String
  date              String   // YYYY-MM-DD
  timeSlot          String   // e.g. "4:00 PM"
  timezone          String   @default("Asia/Kolkata")
  zoomLink          String?
  zoomStartUrl      String?
  zoomMeetingId     String?
  status            String   @default("SCHEDULED")  // SCHEDULED | COMPLETED | CANCELLED
  reminderSent      Boolean  @default(false)
  dailyReminderSent Boolean  @default(false)
  sessionNumber     Int      @default(1)
  createdAt         DateTime @default(now())
  payment           Payment?    @relation(fields: [paymentId],    references: [id])
  enrollment        Enrollment? @relation(fields: [enrollmentId], references: [id])
}
