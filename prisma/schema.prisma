generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  phone          String?
  role           String   @default("PARENT")
  password       String
  approvalStatus String   @default("APPROVED") // PENDING | APPROVED | REJECTED (for TUTOR role)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String?
  parentName    String
  parentEmail   String
  childName     String
  childAge      String
  grade         String
  timezone      String
  subject       String
  tutorName     String
  tutorInitials String
  date          String
  timeSlot      String
  notes         String   @default("")
  monthlyPrice  Int
  status        String   @default("PENDING")
  zoomLink      String?
  zoomStartUrl  String?
  zoomMeetingId String?
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  from      String
  email     String
  subject   String
  message   String
  priority  String   @default("medium")  // low | medium | high
  status    String   @default("open")    // open | closed
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  price       Int      @default(199)
  status      String   @default("active")  // active | inactive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Resource {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("PDF")     // PDF | Image | Link
  subject   String
  size      String   @default("")
  icon      String   @default("📄")
  url       String   @default("")        // download or view URL
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VideoLesson {
  id        String   @id @default(cuid())
  title     String
  subject   String
  duration  String   @default("")
  thumbnail String   @default("📹")      // emoji or image URL
  videoUrl  String   @default("")        // YouTube embed or direct URL
  views     Int      @default(0)
  status    String   @default("active")  // active | inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
